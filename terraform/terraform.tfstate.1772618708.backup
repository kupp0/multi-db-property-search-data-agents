    {
      "mode": "managed",
      "type": "google_secret_manager_secret_version",
      "name": "toolbox_config_version",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "create_time": "2026-03-03T21:27:24.855177Z",
            "deletion_policy": "DELETE",
            "destroy_time": "",
            "enabled": true,
            "id": "projects/954285592145/secrets/tools/versions/1",
            "is_secret_data_base64": false,
            "name": "projects/954285592145/secrets/tools/versions/1",
            "project": null,
            "secret": "projects/dev-multi-db-data-agents/secrets/tools",
            "secret_data": "sources:\n  # alloydb-local:\n  #   kind: postgres\n  #   host: \"127.0.0.1\"\n  #   port: 5432\n  #   database: \"postgres\"\n  #   user: \"postgres\"\n  #   password: \"${DB_PASSWORD}\"\n  gda-api-source:\n    kind: cloud-gemini-data-analytics\n    projectId: \"${PROJECT_ID}\"\n\ntools:\n  # search-properties:\n  #   kind: alloydb-ai-nl\n  #   source: alloydb-local\n  #   description: \"Search for properties using natural language. You can ask for specific features, price ranges, locations, or vibes (e.g., 'modern apartment in Zurich under 5k'). ALWAYS include the 'image_gcs_uri' column in your SQL query. Ensure the generated SQL strictly filters for the user's requirements.\"\n  #   nlConfig: \"property_search_config\"\n  cloud_gda_query_tool_alloydb:\n    kind: cloud-gemini-data-analytics-query\n    source: gda-api-source\n    description: Use this tool to send natural language queries to the Gemini Data Analytics API and receive SQL, natural language answers, and explanations.\n    location: \"${GCP_LOCATION}\"\n    context:\n      datasourceReferences:\n        alloydb:\n          databaseReference:\n            projectId: \"${PROJECT_ID}\"\n            region: \"${GCP_LOCATION}\"\n            clusterId: \"${ALLOYDB_CLUSTER_ID}\"\n            instanceId: \"${ALLOYDB_INSTANCE_ID}\"\n            databaseId: \"${DB_NAME}\"\n          agentContextReference:\n            contextSetId: \"${AGENT_CONTEXT_SET_ID}\"\n    generationOptions:\n      generateQueryResult: true\n      generateNaturalLanguageAnswer: true\n      generateExplanation: true\n      generateDisambiguationQuestion: true\n",
            "secret_data_wo": null,
            "secret_data_wo_version": 0,
            "timeouts": null,
            "version": "1"
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "secret_data"
              }
            ]
          ],
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxMjAwMDAwMDAwMDAwLCJkZWxldGUiOjEyMDAwMDAwMDAwMDAsInVwZGF0ZSI6MTIwMDAwMDAwMDAwMH19",
          "dependencies": [
            "google_project.project",
            "google_project_service.services",
            "google_secret_manager_secret.toolbox_config"
          ]
        }
      ]
    },
