# Google Cloud Project Details
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=europe-west1

# AlloyDB Configuration
# Format: projects/<PROJECT>/locations/<REGION>/clusters/<CLUSTER>/instances/<INSTANCE>
INSTANCE_CONNECTION_NAME=projects/your-project/locations/europe-west1/clusters/your-cluster/instances/your-instance
DB_NAME=search
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1

# AlloyDB Details (Used by scripts)
ALLOYDB_CLUSTER_ID=search-cluster
ALLOYDB_INSTANCE_ID=search-primary



# Agent Configuration
AGENT_CONTEXT_SET_ID_ALLOYDB=your-alloydb-context-set-id
AGENT_CONTEXT_SET_ID_CLOUDSQL_PG=your-cloudsql-pg-context-set-id
AGENT_CONTEXT_SET_ID_SPANNER=your-spanner-context-set-id
